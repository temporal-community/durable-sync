=== publish_entry ===
Publish an entry or multiple entries. Accepts either a single entryId (string) or an array of entryIds (up to 100 entries). For a single entry, it uses the standard publish operation. For multiple entries, it automatically uses bulk publishing.
{
  "type": "object",
  "properties": {
    "spaceId": {
      "type": "string",
      "description": "The ID of the Contentful space"
    },
    "environmentId": {
      "type": "string",
      "description": "The ID of the Contentful environment"
    },
    "entryId": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "maxItems": 100,
      "description": "Array of entry IDs to publish. Single-element array for one entry, or up to MAX_BULK_SIZE per call (default 10, max 100 \u2014 configurable via MAX_BULK_SIZE env var)."
    },
    "dryRun": {
      "type": "boolean",
      "description": "When true, returns a preview of the operation without executing it. Still subject to MAX_BULK_SIZE \u2014 use this to confirm intent for within-limit calls."
    }
  },
  "required": [
    "spaceId",
    "environmentId",
    "entryId"
  ],
  "additionalProperties": false,
  "$schema": "http://json-schema.org/draft-07/schema#"
}

=== list_content_types ===
List content types in a space. Returns a maximum of 10 items per request. Use skip parameter to paginate through results.
{
  "type": "object",
  "properties": {
    "spaceId": {
      "type": "string",
      "description": "The ID of the Contentful space"
    },
    "environmentId": {
      "type": "string",
      "description": "The ID of the Contentful environment"
    },
    "limit": {
      "type": "number",
      "description": "Maximum number of content types to return (max 10)"
    },
    "skip": {
      "type": "number",
      "description": "Skip this many content types for pagination"
    },
    "select": {
      "type": "string",
      "description": "Comma-separated list of fields to return"
    },
    "include": {
      "type": "number",
      "description": "Include this many levels of linked entries"
    },
    "order": {
      "type": "string",
      "description": "Order content types by this field"
    }
  },
  "required": [
    "spaceId",
    "environmentId"
  ],
  "additionalProperties": false,
  "$schema": "http://json-schema.org/draft-07/schema#"
}

=== get_content_type ===
Get details about a specific Contentful content type
{
  "type": "object",
  "properties": {
    "spaceId": {
      "type": "string",
      "description": "The ID of the Contentful space"
    },
    "environmentId": {
      "type": "string",
      "description": "The ID of the Contentful environment"
    },
    "contentTypeId": {
      "type": "string",
      "description": "The ID of the content type to retrieve details for"
    }
  },
  "required": [
    "spaceId",
    "environmentId",
    "contentTypeId"
  ],
  "additionalProperties": false,
  "$schema": "http://json-schema.org/draft-07/schema#"
}

